# Copy this file to secrets.toml and replace with your credentials.
# Streamlit reads ONLY .streamlit/secrets.toml (not a root-level secrets.toml).
#
# Always quote the URL. If your password contains #, @, ", or \, use triple quotes:
# DB_URL = """postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require"""
#
# Use the key DB_URL (SUPABASE_DB_URL is also supported by the app).

DB_URL = """postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require"""
